{
  "name": "ultrasearch",
  "version": "1.3.0",
  "description": "Recap everything the web says about a topic — fan out keyless web search across many backends, fetch + dedupe sources into an evidence dossier, and write a citation-checked, tiered report (with self-contained HTML) in five research modes. A skills.sh agent skill.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "ultrasearch": "scripts/ultrasearch.mjs"
  },
  "files": [
    "SKILL.md",
    "scripts",
    "references",
    "assets",
    "src",
    "docker-compose.yml",
    "docker"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:build": "tsup && git diff --exit-code -- scripts/ultrasearch.mjs",
    "demo": "node scripts/ultrasearch.mjs gather --q \"what is rate limiting\" --mode topic --backends fixture --out /tmp/ultrasearch-demo",
    "eval": "node evals/run.mjs --suite offline",
    "eval:network": "node evals/run.mjs --suite network",
    "release": "semantic-release"
  },
  "keywords": [
    "skills",
    "agent-skill",
    "skills.sh",
    "web-search",
    "research",
    "rag",
    "deep-research",
    "ai-agent"
  ],
  "license": "MIT",
  "author": "maxgfr",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxgfr/ultrasearch"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^20.14.0",
    "semantic-release": "^24.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0",
    "yaml": "^2.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
